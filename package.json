{
  "name": "consortium-carshare-prototype",
  "version": "1.0.0",
  "description": "Consortium blockchain based car sharing prototype",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:all": "concurrently -n api,web -c blue,green \"npm run dev\" \"npm run dev:frontend\"",
    "contract:compile": "node scripts/compile-contract.js",
    "setup": "npm install && npm run contract:compile",
    "download-car-photos": "node scripts/download-car-photos.mjs",
    "hardhat": "cd contracts && npx hardhat",
    "hardhat:node": "cd contracts && npx hardhat node",
    "hardhat:compile": "cd contracts && npx hardhat compile",
    "hardhat:deploy": "cd contracts && npx hardhat run scripts/deploy-escrow.js --network localhost",
    "hardhat:test": "cd contracts && npx hardhat test"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "ethers": "^6.16.0",
    "express": "^4.19.2",
    "multer": "^2.1.1",
    "mysql2": "^3.15.2",
    "solc": "^0.8.30",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.6",
    "concurrently": "^9.2.1",
    "hardhat": "^3.2.0",
    "nodemon": "^3.1.0"
  }
}
